{
  "name": "sanguosha-web",
  "version": "0.1.0",
  "description": "三国杀在线对战平台 — Claude Code Agent 开发项目",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/network/server.ts",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild src/network/server.ts --bundle --platform=node --target=node20 --outfile=dist-server/server.js --external:express --external:socket.io --format=esm",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "memory:update": "node scripts/update-memory.js",
    "memory:compress": "node scripts/compress-memory.js",
    "memory:export": "node scripts/export-memory.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "framer-motion": "^10.16.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.0",
    "@types/react": "^18.2.25",
    "@types/react-dom": "^18.2.11",
    "@vitejs/plugin-react": "^4.1.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.1",
    "esbuild": "^0.27.3",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.11",
    "vitest": "^0.34.6"
  }
}
